{
  "name": "@foundry-rs/foundry-toolchain",
  "version": "1.5.0",
  "license": "SEE LICENSE IN LICENSE",
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "main": "dist/index.js",
  "keywords": [
    "foundry",
    "ethereum",
    "solidity",
    "evm",
    "forge",
    "cast",
    "dapp",
    "dapptools"
  ],
  "scripts": {
    "build": "tsc && ncc build lib/index.js -o dist --source-map --minify && ncc build lib/save.js -o dist/save --source-map --minify && node -e \"require('node:fs').rmSync('lib', { recursive: true, force: true })\"",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@actions/cache": "6.1.0",
    "@actions/core": "3.0.1",
    "@actions/github": "9.1.1",
    "@actions/tool-cache": "4.0.0"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@vercel/ncc": "0.44.1",
    "prettier": "3.9.5",
    "typescript": "7.0.2"
  }
}
